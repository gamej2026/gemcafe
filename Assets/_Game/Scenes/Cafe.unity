  contentText: {fileID: 131563018}
  scrollRect: {fileID: 1941671159}
  recipeText: "\uC5FC\uB77C \uC218\uC5FC\n\t\uD654\uD55C \uC2DC\uC6D0\uD568\n\t\uC5F4\uC744
    \uC2DD\uD600\uC90C\n\uB3C4\uB77C\uC9C0\n\t\uC4F4\uB9DB\t\n\t\uC18D\uC4F0\uB9BC\uC744
    \uC911\uD654\uD568\n\uC0BC\uB3C4\uCC9C \uAC15\uBB3C\n\t\uC2E0\uB9DB\t\n\t\uC785\uC548\uC744
    \uAE54\uB054\uD558\uAC8C \uD574\uC90C\n\uD638\uB791\uC774 \uB2F4\uBC43\uC7AC\n\t\uC624\uB798\uB41C
    \uD5A5\t\n\t\uD5A5\uC218\uB97C \uBD88\uB7EC\uC77C\uC73C\uD0B4\n\uACF6\uAC10\t\n\t\uB2E8\uB9DB\t\uD65C\uB825\uC744
    \uBD88\uC5B4\uC90C\n\uD1A0\uB07C \uAC04\n\t\uBD80\uB4DC\uB7EC\uC6C0\t\n\t\uBB49\uD074\uD55C
    \uAC10\uAC01\uC744 \uC90C\n\uCC98\uB140\uADC0\uC2E0 \uBA38\uB9AC\uCE74\uB77D\n\t\uAC10\uCE60\uB9DB\t\n\t\uAC01\uC131
    \uD6A8\uACFC\uB97C \uC90C"
  emptyMessage: "\uB808\uC2DC\uD53C \uB0B4\uC6A9\uC774 \uC5C6\uC2B5\uB2C8\uB2E4."
